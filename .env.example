# Milk & Honey Wigs Production Portal — environment variables
# Copy to .env.local for local dev. In Vercel, set these in Project Settings > Environment Variables.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to the browser). Used for admin-side operations
# such as creating users / bypassing RLS in trusted server actions only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
